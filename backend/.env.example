PORT=8800
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=present
DB_INIT_SCRIPT=../database/present_db.sql

# Use uma string longa e aleatória (mínimo 16 chars).
JWT_ACCESS_SECRET=change-me-to-a-long-random-string

# Opcional (segundos)
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800

